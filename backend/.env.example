# LogWatch Backend — Environment Configuration
# Copy this to .env and fill in your actual AWS/Clerk secrets

# --- Server Config ---
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3002

# --- AWS Credentials ---
# Ensure these have CloudWatchLogsFullAccess, AmazonS3FullAccess, and AmazonDynamoDBFullAccess
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_secret_access_key_here

# --- CloudWatch Log Groups ---
# Must match your AWS Lambda function destinations
CW_LOG_GROUP_LOGIN=/aws/lambda/logwatch-login
CW_LOG_GROUP_UPLOAD=/aws/lambda/logwatch-upload
CW_LOG_GROUP_PAYMENT=/aws/lambda/logwatch-payment

# --- Storage & Data ---
S3_BUCKET_NAME=your-logwatch-archive-bucket
DYNAMO_TABLE_NAME=logwatch-alerts

# --- Archiver Logic ---
LOG_ARCHIVE_INTERVAL_MINUTES=10
LOG_FETCH_LIMIT=150
