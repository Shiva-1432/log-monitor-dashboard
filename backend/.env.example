# ─────────────────────────────────────────────────────────────
# LogWatch Backend — Environment Variables
# Copy this to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# Server
PORT=4000
NODE_ENV=development

# CORS — your Next.js frontend URL
FRONTEND_URL=http://localhost:3000

# AWS credentials (IAM user: logwatch-backend)
# Created in Phase 3 → iam/backend-cloudwatch-policy.json
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=REPLACE_ME
AWS_SECRET_ACCESS_KEY=REPLACE_ME

# CloudWatch Log Groups (created automatically by Lambda)
CW_LOG_GROUP_LOGIN=/aws/lambda/logwatch-login
CW_LOG_GROUP_UPLOAD=/aws/lambda/logwatch-upload
CW_LOG_GROUP_PAYMENT=/aws/lambda/logwatch-payment

# How many log events to fetch per request
LOG_FETCH_LIMIT=100

# API Gateway URL (used by generate-traffic.sh in Phase 3)
API_GATEWAY_URL=https://REPLACE_ME.execute-api.us-east-1.amazonaws.com/prod
