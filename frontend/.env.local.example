# LogWatch Frontend — Environment Configuration
# Copy this to .env.local and fill in your actual Clerk/Backend URLs

# --- Backend Connectivity ---
# Root API URL for Express server (Render in Prod, localhost:4000 in Dev)
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000

# --- Clerk Authentication ---
# Get these from your Clerk Dashboard (clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# --- WebSocket Hub (Optional) ---
# If using AWS WebSocket API for live logs
NEXT_PUBLIC_WS_URL=wss://your-api-id.execute-api.region.amazonaws.com/prod
